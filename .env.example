# Backblaze B2
B2_KEY_ID=your_key_id
B2_APP_KEY=your_app_key
B2_BUCKET_NAME=your_bucket_name

# Admin authentication
ADMIN_PASSWORD=your_secure_password
ADMIN_SESSION_SECRET=random_long_secret_string

# Student authentication (requires DATABASE_URL)
STUDENT_AUTH_REQUIRED=false
STUDENT_SESSION_SECRET=another_random_long_secret_string

# PostgreSQL (Render managed DB — set automatically on Render via DATABASE_URL)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=false

# Optional Stripe billing
STRIPE_ENABLED=false
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_CLASS=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_ALLOW_STUDENT_UPGRADES=false

# Optional: skip automatic CORS updates on each server start (set true on Render after first deploy)
# B2_SKIP_CORS_UPDATE=true

# Optional: if bucket exists but name lookup fails, set bucket ID from B2 console
# B2_BUCKET_ID=

# Public bucket for shared common assets (direct Backblaze URLs + CORS)
# Created automatically as {B2_BUCKET_NAME}-public if omitted
# B2_PUBLIC_BUCKET_NAME=hotspot-vr-public
# B2_PUBLIC_BUCKET_ID=

# Optional: explicit public URL when behind Render/proxy (student project hosting only)
# SERVER_BASE_URL=https://your-app.onrender.com

# Server port (Render sets PORT automatically)
# PORT=3000
