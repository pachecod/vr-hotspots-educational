# Backblaze B2
B2_KEY_ID=your_key_id
B2_APP_KEY=your_app_key
B2_BUCKET_NAME=your_bucket_name

# Admin authentication
ADMIN_PASSWORD=your_secure_password
ADMIN_SESSION_SECRET=random_long_secret_string

# Student authentication (requires DATABASE_URL)
STUDENT_AUTH_REQUIRED=false
STUDENT_SESSION_SECRET=another_random_long_secret_string

# Local Test User / Guest mode
LOCAL_TEST_USER_ENABLED=false
# On Render/production, also set LOCAL_TEST_USER_ALLOW_PRODUCTION=true to show "Continue as Guest"
# LOCAL_TEST_USER_ALLOW_PRODUCTION=false

# Welcome-screen sample projects (requires DATABASE_URL + B2 for combined ZIP bundles)
PUBLIC_PLAYGROUND_ENABLED=false
# Optional: dedicated key for encrypting retrievable student passwords (defaults to STUDENT_SESSION_SECRET)
# STUDENT_PASSWORD_ENCRYPTION_SECRET=another_random_long_secret_string

# PostgreSQL (Render managed DB — set automatically on Render via DATABASE_URL)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=false

# Optional Stripe billing
STRIPE_ENABLED=false
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_CLASS=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_ALLOW_STUDENT_UPGRADES=false

# Optional: skip automatic CORS updates on each server start (set true on Render after first deploy)
# B2_SKIP_CORS_UPDATE=true

# Optional: if bucket exists but name lookup fails, set bucket ID from B2 console
# B2_BUCKET_ID=

# Public bucket for shared common assets (direct Backblaze URLs + CORS)
# Created automatically as {B2_BUCKET_NAME}-public if omitted
# B2_PUBLIC_BUCKET_NAME=hotspot-vr-public
# B2_PUBLIC_BUCKET_ID=

# Optional: explicit public URL when behind Render/proxy (student project hosting only)
# SERVER_BASE_URL=https://your-app.onrender.com

# Server port (Render sets PORT automatically)
# PORT=3000

# Optional Ridey AI (flat page editor)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=1500
# OPENAI_TEMPERATURE=0.2
# RIDEY_ENABLED=false
# RIDEY_RATE_LIMIT_PER_HOUR=20
# RIDEY_PERSONA=

# VIDEO_TRANSCODE_ENABLED=false
# VIDEO_TRANSCODE_ADMIN_ONLY=true
# VIDEO_SCENE_SERVER_UPLOAD=false
# VIDEO_EXPORT_URL_MODE=false
