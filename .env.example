# Backblaze B2
B2_KEY_ID=your_key_id
B2_APP_KEY=your_app_key
B2_BUCKET_NAME=your_bucket_name

# Admin authentication
ADMIN_PASSWORD=your_secure_password
ADMIN_SESSION_SECRET=random_long_secret_string

# Optional: if bucket exists but name lookup fails, set bucket ID from B2 console
# B2_BUCKET_ID=

# Public bucket for shared common assets (direct Backblaze URLs + CORS)
# Created automatically as {B2_BUCKET_NAME}-public if omitted
# B2_PUBLIC_BUCKET_NAME=hotspot-vr-public
# B2_PUBLIC_BUCKET_ID=

# Optional: explicit public URL when behind Render/proxy (student project hosting only)
# SERVER_BASE_URL=https://your-app.onrender.com

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_BASE=http://localhost:3000

# Server port (Render sets PORT automatically)
# PORT=3000
