{
  "name": "vr-hotspots-educational",
  "version": "2.0.0",
  "description": "VR Hotspots Editor with Educational Backend",
  "main": "simple-server.js",
  "scripts": {
    "start": "node simple-server.js",
    "dev": "concurrently -n api,vite -c blue,green \"nodemon simple-server.js\" \"vite\"",
    "dev:feature": "concurrently -n api,vite -c blue,magenta \"PORT=3001 nodemon simple-server.js\" \"API_TARGET=http://localhost:3001 VITE_PORT=5174 vite\"",
    "dev:api": "nodemon simple-server.js",
    "vite": "vite",
    "dev:vite": "concurrently -n api,vite -c blue,green \"node simple-server.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "setup-b2-cors": "node set_cors.js",
    "db:migrate": "node -e \"require('dotenv').config(); require('./db/migrate').runMigrations().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "aframe": "^1.7.1",
    "aframe-extras": "^7.6.0",
    "archiver": "^6.0.2",
    "backblaze-b2": "^1.7.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "stripe": "^22.2.2",
    "unzipper": "^0.10.14"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.0.1",
    "vite": "^6.2.0"
  }
}
